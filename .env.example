# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# PostgreSQL connection string (SQLAlchemy 2.x + psycopg v3 dialect).
# Local dev form (adjust the port to your instance; native installs may use 5433
# if 5432 is taken; the docker-compose route publishes 5432):
DATABASE_URL=postgresql+psycopg://volrisk:change-me@localhost:5433/volrisk

# Cloud (Neon) form — SSL is REQUIRED. This exact form is what goes into the
# GitHub Actions secret DATABASE_URL for the nightly job (never commit it):
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@ep-xxxx-xxxx.REGION.aws.neon.tech/volrisk?sslmode=require

# Optional: separate throwaway database for integration tests.
# pytest skips the DB integration tests when this is unset.
VOLRISK_TEST_DATABASE_URL=postgresql+psycopg://volrisk:change-me@localhost:5433/volrisk_test

# Used only by docker-compose.yml (the containerized alternative route).
POSTGRES_USER=volrisk
POSTGRES_PASSWORD=change-me
POSTGRES_DB=volrisk
